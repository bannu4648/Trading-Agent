# --- LLM Provider (repo root .env) ---
# auto | mistral | ollama | groq | gemini | deepseek | openai | anthropic
# "auto" picks first available key: Mistral → Groq → Gemini → … → Ollama
LLM_PROVIDER=auto

# --- API Keys (only your active provider is required) ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
# Throttle (default on): ~1 req/s + 28/min rolling window — avoids 429 on free tier
# MISTRAL_THROTTLE=true
# MISTRAL_MIN_INTERVAL_SEC=1.05
# MISTRAL_MAX_PER_MINUTE=28
# Optional: custom API base (rare; default is Mistral cloud)
# MISTRAL_API_BASE_URL=https://api.mistral.ai
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Model names (defaults are fine for most cases) ---
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_MODEL=deepseek-chat
GEMINI_MODEL=gemini-2.0-flash

# --- Agent weights (must sum to 1.0) ---
WEIGHT_NEWS=0.35
WEIGHT_SOCIAL=0.25
WEIGHT_ANALYST=0.25
WEIGHT_WEB=0.15

# Faster sentiment: skip social + web + debate LLM (news + analyst + summary only).
# Put this in repo root .env for backend runs. Env name: SENTIMENT_FAST_PIPELINE
# SENTIMENT_FAST_PIPELINE=true
